# .env.mcp - MCP Server Environment Configuration
# Copy this to .env.mcp and fill in your credentials

# GitHub
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Jira
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=user@example.com
# JIRA_API_TOKEN=xxxxxxxx

# Slack
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx

# PostgreSQL
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Redis
# REDIS_URL=redis://localhost:6379/0

# AWS
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
# AWS_REGION=us-east-1

# Sentry
# SENTRY_TOKEN=sntrys_xxxxxxxxxxxx
# SENTRY_ORG_SLUG=my-org

# Datadog
# DATADOG_API_KEY=xxxxxxxxxxxx
# DATADOG_APP_KEY=xxxxxxxxxxxx
# DATADOG_SITE=datadoghq.com

# Kubernetes (uses default ~/.kube/config if not set)
# KUBECONFIG=/path/to/kubeconfig
